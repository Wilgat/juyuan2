<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.iotlighting.mapper.SysStaffMapper">

    <resultMap type="SysStaff" id="SysStaffResult">
        <result property="staffId" column="staff_id"/>
        <result property="userId" column="user_id"/>
        <result property="staffNumber" column="staff_number"/>
        <result property="staffPosition" column="staff_position"/>
        <result property="licenseNumber" column="license_number"/>
        <result property="password" column="password"/>
        <result property="userName" column="user_name"/>
        <result property="nickName" column="nick_name"/>
        <collection property="roleKeyList" javaType="java.util.List" ofType="Long" column="{userId=user_id}"
                    select="selectChildStrings"/>
    </resultMap>

    <select id="selectChildStrings" resultType="Long">
        SELECT role_id
        FROM sys_user_role
        WHERE user_id = #{userId}
    </select>

    <sql id="selectSysStaffVo">
        select distinct ss.staff_id,
                        ss.staff_number,
                        ss.staff_position,
                        ss.license_number,
                        su.user_id,
                        su.nick_name,
                        su.user_name
        from sys_user su
                 left join sys_staff ss on (su.user_id = ss.user_id)
                 left join sys_user_role sur on (su.user_id = sur.user_id)
                 left join sys_role sr on (sr.role_id = sur.role_id)
                 inner join sys_dept d on (su.dept_id = d.dept_id)
    </sql>

    <select id="selectSysStaffList" parameterType="SysStaff" resultMap="SysStaffResult">
        <include refid="selectSysStaffVo"/>
        <where>
            su.del_flag = '0' and su.user_id not in (select user_id from sys_user_role where role_id in (select role_id
            from sys_role where
            role_key like '%admin%'))
            <if test="userId != null ">and su.user_id = #{userId}</if>
            <if test="staffNumber != null  and staffNumber != ''">and ss.staff_number = #{staffNumber}</if>
            <if test="staffPosition != null  and staffPosition != ''">and ss.staff_position = #{staffPosition}</if>
            <if test="licenseNumber != null  and licenseNumber != ''">and ss.license_number = #{licenseNumber}</if>
            <if test="password != null  and password != ''">and ss.password = #{password}</if>
        </where>
        <!-- 数据范围过滤 -->
        ${params.dataScope}
    </select>

    <select id="selectSysStaffByUserId" parameterType="Long" resultMap="SysStaffResult">
        <include refid="selectSysStaffVo"/>
        where su.user_id = #{userId} and su.del_flag = '0'
    </select>

    <insert id="insertSysStaff" parameterType="SysStaff" useGeneratedKeys="true" keyProperty="staffId">
        insert into sys_staff
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="staffNumber != null">staff_number,</if>
            <if test="staffPosition != null">staff_position,</if>
            <if test="licenseNumber != null">license_number,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="staffNumber != null">#{staffNumber},</if>
            <if test="staffPosition != null">#{staffPosition},</if>
            <if test="licenseNumber != null">#{licenseNumber},</if>
        </trim>
    </insert>

    <update id="updateSysStaff" parameterType="SysStaff">
        update sys_staff
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="staffNumber != null">staff_number = #{staffNumber},</if>
            <if test="staffPosition != null">staff_position = #{staffPosition},</if>
            <if test="licenseNumber != null">license_number = #{licenseNumber},</if>
            <if test="password != null">password = #{password},</if>
        </trim>
        where staff_id = #{staffId}
    </update>

    <delete id="deleteSysStaffByStaffId" parameterType="Long">
        delete
        from sys_staff
        where staff_id = #{staffId}
    </delete>

    <delete id="deleteSysStaffByStaffIds" parameterType="String">
        delete from sys_staff where staff_id in
        <foreach item="staffId" collection="array" open="(" separator="," close=")">
            #{staffId}
        </foreach>
    </delete>
</mapper>
